<%- include("../partials/head") %>
<%- include("../partials/header") %>

<section class="panel">
  <p class="eyebrow">Faculty detail</p>
  <div class="faculty-detail">
    <img
      class="faculty-photo faculty-photo-detail"
      src="/images/faculty/<%= faculty.photoFile %>"
      alt="Profile photo of <%= faculty.name %>"
    />
    <div>
      <h2><%= faculty.name %></h2>
      <p><strong>Department:</strong> <%= faculty.department %></p>
      <p><strong>Title:</strong> <%= faculty.title %></p>
      <p><strong>Office:</strong> <%= faculty.office %></p>
      <p><strong>Phone:</strong> <%= faculty.phone %></p>
      <p><strong>Email:</strong> <%= faculty.email %></p>
    </div>
  </div>
</section>

<%- include("../partials/footer") %>
