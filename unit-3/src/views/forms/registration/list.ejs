<%- include("../../partials/head") %>
<%- include("../../partials/header") %>

<section class="panel">
  <p class="eyebrow">Users</p>
  <h2>Registered accounts</h2>

  <% if (users && users.length > 0) { %>
    <div class="users-list">
      <% users.forEach((account) => { %>
        <% const canEdit = user && (user.id === account.id || user.roleName === "admin"); %>
        <% const canDelete = user && user.roleName === "admin" && user.id !== account.id; %>
        <div class="user-card">
          <div class="user-header">
            <h3><%= account.name %></h3>
            <span class="user-id">ID: <%= account.id %></span>
          </div>
          <div class="user-details">
            <div class="detail-item">
              <div class="label">Email</div>
              <div class="value"><%= account.email %></div>
            </div>
            <div class="detail-item">
              <div class="label">Role</div>
              <div class="value"><%= account.roleName || "user" %></div>
            </div>
            <div class="detail-item">
              <div class="label">Registered</div>
              <div class="value"><%= new Date(account.created_at).toLocaleDateString() %></div>
            </div>
            <% if (canEdit || canDelete) { %>
              <div class="user-actions">
                <% if (canEdit) { %>
                  <a class="button-link" href="/register/<%= account.id %>/edit">Edit</a>
                <% } %>
                <% if (canDelete) { %>
                  <form method="POST" action="/register/<%= account.id %>/delete" style="display:inline;">
                    <button class="button-danger" type="submit" onclick="return confirm('Are you sure you want to delete this account?');">Delete</button>
                  </form>
                <% } %>
              </div>
            <% } %>
          </div>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <p class="no-users">No users registered yet.</p>
  <% } %>
</section>

<%- include("../../partials/footer") %>
