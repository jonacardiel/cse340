<%- include("../../partials/head") %>
<%- include("../../partials/header") %>

<section class="contact-responses">
  <h2>Contact Form Submissions</h2>

  <% if (responses.length > 0) { %>
    <% responses.forEach((response) => { %>
      <div class="response-item">
        <h3 class="response-subject"><%= response.subject %></h3>
        <p class="response-message"><%= response.message %></p>
        <p class="response-date">Submitted: <%= new Date(response.submitted).toLocaleDateString() %></p>
      </div>
    <% }) %>
  <% } else { %>
    <p class="no-responses">No contact form submissions yet.</p>
  <% } %>
</section>

<%- include("../../partials/footer") %>
