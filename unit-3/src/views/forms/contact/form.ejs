<%- include("../../partials/head") %>
<%- include("../../partials/header") %>

<section class="contact-form">
  <h2>Contact Us</h2>

  <% if (errors.length > 0) { %>
    <div class="error-list">
      <ul>
        <% errors.forEach((error) => { %>
          <li><%= error.msg %></li>
        <% }) %>
      </ul>
    </div>
  <% } %>

  <form method="POST" action="/contact">
    <div class="form-group">
      <label for="subject">Subject</label>
      <input type="text" id="subject" name="subject" placeholder="What is this message about?" minlength="2" required value="<%= values.subject %>" />
    </div>

    <div class="form-group">
      <label for="message">Message</label>
      <textarea id="message" name="message" rows="6" placeholder="Please provide details about your question or feedback..." minlength="10" required><%= values.message %></textarea>
    </div>

    <button type="submit">Send Message</button>
  </form>
</section>

<%- include("../../partials/footer") %>
