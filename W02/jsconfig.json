{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true
  },
  "include": [
    "server.js",
    "public/**/*.js",
    "src/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "**/node_modules/*"
  ]
}
