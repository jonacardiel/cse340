<%- include("../partials/head") %>
<%- include("../partials/header") %>
<main class="page-shell content-layout">
  <section class="content-card">
    <p class="eyebrow">Employee / Owner</p>
    <h1>Manage Service Requests</h1>
    <p>Update request stage and add notes that become part of the customer-visible history.</p>
  </section>

  <% for (const request of requests) { %>
    <section class="content-card request-card">
      <div class="request-header">
        <div>
          <p class="eyebrow"><%= request.status %></p>
          <h2><%= request.service_type %></h2>
          <p><%= request.customer_first_name %> <%= request.customer_last_name %> · <%= request.customer_email %></p>
          <p><a href="/inventory/<%= request.vehicle_slug %>"><%= request.vehicle_name %></a></p>
        </div>
        <div>
          <p>Preferred date: <%= request.requested_date ? new Date(request.requested_date).toLocaleDateString() : "Not set" %></p>
          <p>Submitted: <%= new Date(request.created_at).toLocaleString() %></p>
        </div>
      </div>

      <p><strong>Customer note:</strong> <%= request.customer_notes %></p>

      <form class="auth-form" method="post" action="/service-requests/<%= request.id %>/status">
        <div class="form-grid">
          <div class="field-group">
            <label for="status-<%= request.id %>">Status</label>
            <select id="status-<%= request.id %>" name="status">
              <option value="Submitted" <%= request.status === "Submitted" ? "selected" : "" %>>Submitted</option>
              <option value="In Progress" <%= request.status === "In Progress" ? "selected" : "" %>>In Progress</option>
              <option value="Completed" <%= request.status === "Completed" ? "selected" : "" %>>Completed</option>
            </select>
          </div>
          <div class="field-group field-group-full">
            <label for="statusNote-<%= request.id %>">Status Note</label>
            <textarea id="statusNote-<%= request.id %>" name="statusNote" rows="3" placeholder="Example: Technician inspection started at 9:30 AM."></textarea>
          </div>
        </div>
        <button class="button" type="submit">Update Request</button>
      </form>

      <h3>History</h3>
      <% const requestNotes = notesByRequestId[request.id] || []; %>
      <% if (requestNotes.length === 0) { %>
        <p class="muted">No notes yet.</p>
      <% } %>
      <% for (const note of requestNotes) { %>
        <div class="review-card">
          <p class="eyebrow"><%= note.note_type %></p>
          <p><%= note.note_text %></p>
          <p class="muted">
            <%= note.first_name ? `${note.first_name} ${note.last_name?.charAt(0) || ""}.` : "System" %>
            · <%= new Date(note.created_at).toLocaleString() %>
          </p>
        </div>
      <% } %>
    </section>
  <% } %>
</main>
<%- include("../partials/footer") %>
