<%- include("../partials/head") %>
<%- include("../partials/header") %>
<main class="page-shell auth-layout">
  <section class="content-card">
    <p class="eyebrow"><%= userRole %> controls</p>
    <h1>Edit Vehicle</h1>
    <p><strong><%= vehicle.name %></strong> · <a href="/inventory/<%= vehicle.slug %>">View public detail</a></p>

    <% if (errors.length > 0) { %>
      <ul class="field-error-list">
        <% for (const error of errors) { %>
          <li><%= error.msg %></li>
        <% } %>
      </ul>
    <% } %>

    <form class="auth-form" method="post" action="/admin/vehicles/<%= vehicle.id %>/edit">
      <div class="form-grid">
        <% if (userRole === "owner") { %>
          <div class="field-group">
            <label for="categoryId">Category</label>
            <select id="categoryId" name="categoryId">
              <option value="">Unassigned</option>
              <% for (const category of categories) { %>
                <option value="<%= category.id %>" <%= Number(vehicle.category_id) === Number(category.id) ? "selected" : "" %>><%= category.name %></option>
              <% } %>
            </select>
          </div>
          <div class="field-group">
            <label for="name">Name</label>
            <input id="name" name="name" type="text" value="<%= vehicle.name %>">
          </div>
          <div class="field-group">
            <label for="year">Year</label>
            <input id="year" name="year" type="number" value="<%= vehicle.year %>">
          </div>
          <div class="field-group">
            <label for="make">Make</label>
            <input id="make" name="make" type="text" value="<%= vehicle.make %>">
          </div>
          <div class="field-group">
            <label for="model">Model</label>
            <input id="model" name="model" type="text" value="<%= vehicle.model %>">
          </div>
          <div class="field-group">
            <label for="mileage">Mileage</label>
            <input id="mileage" name="mileage" type="number" value="<%= vehicle.mileage %>">
          </div>
          <div class="field-group">
            <label for="transmission">Transmission</label>
            <input id="transmission" name="transmission" type="text" value="<%= vehicle.transmission %>">
          </div>
          <div class="field-group">
            <label for="fuelType">Fuel Type</label>
            <input id="fuelType" name="fuelType" type="text" value="<%= vehicle.fuel_type %>">
          </div>
          <div class="field-group">
            <label for="drivetrain">Drivetrain</label>
            <input id="drivetrain" name="drivetrain" type="text" value="<%= vehicle.drivetrain %>">
          </div>
          <div class="field-group">
            <label for="color">Color</label>
            <input id="color" name="color" type="text" value="<%= vehicle.color || "" %>">
          </div>
          <div class="field-group">
            <label for="vin">VIN</label>
            <input id="vin" name="vin" type="text" value="<%= vehicle.vin %>">
          </div>
          <div class="field-group">
            <label for="imageUrl">Primary Image URL</label>
            <input id="imageUrl" name="imageUrl" type="url" value="<%= vehicle.primary_image || "" %>">
          </div>
          <div class="field-group">
            <label for="imageAlt">Image Alt Text</label>
            <input id="imageAlt" name="imageAlt" type="text" value="<%= vehicle.primary_image_alt || "" %>">
          </div>
        <% } %>

        <div class="field-group">
          <label for="price">Price</label>
          <input id="price" name="price" type="number" step="0.01" value="<%= vehicle.price %>">
        </div>

        <div class="field-group field-group-full">
          <label for="description">Description</label>
          <textarea id="description" name="description" rows="4"><%= vehicle.description %></textarea>
        </div>

        <% if (userRole === "owner") { %>
          <div class="inline-actions field-group-full">
            <label><input name="isFeatured" type="checkbox" <%= vehicle.is_featured ? "checked" : "" %>> Featured</label>
            <label><input name="isAvailable" type="checkbox" <%= vehicle.is_available ? "checked" : "" %>> Available</label>
          </div>
        <% } else { %>
          <div class="inline-actions field-group-full">
            <label><input name="isAvailable" type="checkbox" <%= vehicle.is_available ? "checked" : "" %>> Available</label>
          </div>
        <% } %>
      </div>

      <div class="inline-actions">
        <button class="button" type="submit">Save Vehicle</button>
        <a class="button button-secondary" href="/admin/vehicles">Back</a>
      </div>
    </form>
  </section>
</main>
<%- include("../partials/footer") %>
