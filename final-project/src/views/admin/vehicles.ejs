<%- include("../partials/head") %>
<%- include("../partials/header") %>
<main class="page-shell content-layout">
  <section class="content-card">
    <p class="eyebrow"><%= userRole %> controls</p>
    <h1>Manage Inventory Vehicles</h1>
    <p>Employee role can edit price, availability, and description. Owner role can add or remove vehicles and update all fields.</p>
  </section>

  <% if (userRole === "owner") { %>
    <section class="content-card">
      <h2>Add Vehicle</h2>
      <% if (errors.length > 0) { %>
        <ul class="field-error-list">
          <% for (const error of errors) { %>
            <li><%= error.msg %></li>
          <% } %>
        </ul>
      <% } %>
      <form class="auth-form" method="post" action="/admin/vehicles">
        <div class="form-grid">
          <div class="field-group">
            <label for="categoryId">Category</label>
            <select id="categoryId" name="categoryId">
              <option value="">Unassigned</option>
              <% for (const category of categories) { %>
                <option value="<%= category.id %>"><%= category.name %></option>
              <% } %>
            </select>
          </div>
          <div class="field-group">
            <label for="name">Name</label>
            <input id="name" name="name" type="text" value="<%= values.name || "" %>">
          </div>
          <div class="field-group">
            <label for="year">Year</label>
            <input id="year" name="year" type="number" value="<%= values.year || "" %>">
          </div>
          <div class="field-group">
            <label for="make">Make</label>
            <input id="make" name="make" type="text" value="<%= values.make || "" %>">
          </div>
          <div class="field-group">
            <label for="model">Model</label>
            <input id="model" name="model" type="text" value="<%= values.model || "" %>">
          </div>
          <div class="field-group">
            <label for="price">Price</label>
            <input id="price" name="price" type="number" step="0.01" value="<%= values.price || "" %>">
          </div>
          <div class="field-group">
            <label for="mileage">Mileage</label>
            <input id="mileage" name="mileage" type="number" value="<%= values.mileage || "" %>">
          </div>
          <div class="field-group">
            <label for="transmission">Transmission</label>
            <input id="transmission" name="transmission" type="text" value="<%= values.transmission || "" %>">
          </div>
          <div class="field-group">
            <label for="fuelType">Fuel Type</label>
            <input id="fuelType" name="fuelType" type="text" value="<%= values.fuelType || "" %>">
          </div>
          <div class="field-group">
            <label for="drivetrain">Drivetrain</label>
            <input id="drivetrain" name="drivetrain" type="text" value="<%= values.drivetrain || "" %>">
          </div>
          <div class="field-group">
            <label for="color">Color</label>
            <input id="color" name="color" type="text" value="<%= values.color || "" %>">
          </div>
          <div class="field-group">
            <label for="vin">VIN</label>
            <input id="vin" name="vin" type="text" value="<%= values.vin || "" %>">
          </div>
          <div class="field-group">
            <label for="imageUrl">Primary Image URL</label>
            <input id="imageUrl" name="imageUrl" type="url" value="<%= values.imageUrl || "" %>">
          </div>
          <div class="field-group">
            <label for="imageAlt">Image Alt Text</label>
            <input id="imageAlt" name="imageAlt" type="text" value="<%= values.imageAlt || "" %>">
          </div>
          <div class="field-group field-group-full">
            <label for="description">Description</label>
            <textarea id="description" name="description" rows="4"><%= values.description || "" %></textarea>
          </div>
          <div class="inline-actions field-group-full">
            <label><input name="isFeatured" type="checkbox"> Featured</label>
            <label><input name="isAvailable" type="checkbox" checked> Available</label>
          </div>
        </div>
        <button class="button" type="submit">Create Vehicle</button>
      </form>
    </section>
  <% } %>

  <section class="content-card">
    <h2>Current Inventory Records</h2>
    <div class="admin-list">
      <% for (const vehicle of vehicles) { %>
        <article class="review-card">
          <h3><%= vehicle.name %></h3>
          <p><%= vehicle.year %> <%= vehicle.make %> <%= vehicle.model %></p>
          <p>Category: <%= vehicle.category_name || "Unassigned" %> · Price: $<%= Number(vehicle.price).toLocaleString() %></p>
          <p class="muted"><%= vehicle.is_available ? "Available" : "Unavailable" %> · VIN <%= vehicle.vin %></p>
          <div class="inline-actions">
            <a class="button" href="/admin/vehicles/<%= vehicle.id %>/edit">Edit</a>
            <% if (userRole === "owner") { %>
              <form method="post" action="/admin/vehicles/<%= vehicle.id %>/delete">
                <button class="pill" type="submit">Delete</button>
              </form>
            <% } %>
          </div>
        </article>
      <% } %>
    </div>
  </section>
</main>
<%- include("../partials/footer") %>
